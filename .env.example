# Google OAuth credentials (from console.cloud.google.com).
# Register `<MARGIN_PUBLIC_BASE_URL>/api/auth/callback/google` as an
# authorized redirect URI (locally: http://localhost:8787/api/auth/callback/google).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Drive Picker config (only needed for the extension's "add doc" flow).
#   GOOGLE_API_KEY        — a public "API key" credential from the same GCP
#                           project as the OAuth client. Restrict it to the
#                           Picker API in the Cloud Console.
#   GOOGLE_PROJECT_NUMBER — the numeric GCP project number (NOT the project
#                           ID). Find it on Cloud Console → "Project info".
GOOGLE_API_KEY=
GOOGLE_PROJECT_NUMBER=

# 32-byte master key for envelope encryption of Google refresh tokens at
# rest, base64-encoded. Generate with:
#   bun -e 'console.log(Buffer.from(crypto.getRandomValues(new Uint8Array(32))).toString("base64"))'
MARGIN_MASTER_KEY=

# Better Auth signing/encryption secret. MUST be different from
# MARGIN_MASTER_KEY — that one only protects Google refresh tokens at rest.
# At least 32 chars of random data. Generate with:
#   bun -e 'console.log(Buffer.from(crypto.getRandomValues(new Uint8Array(32))).toString("base64"))'
BETTER_AUTH_SECRET=

# SQLite database file
MARGIN_DB_PATH=./margin.db

# Public origin of this backend (no trailing slash). When set, the server
# auto-subscribes a Drive files.watch channel on every new version and runs
# the renew + polling loops in-process. Leave blank in local dev.
# MARGIN_PUBLIC_BASE_URL=https://margin-server.fly.dev

# Set to 1 to allow `bun margin e2e seed-project …` to write directly into
# project + version tables, bypassing Drive validation. Used by the
# chrome-devtools-mcp harness against a throwaway local DB. Leave unset
# elsewhere — the CLI refuses to seed without it.
# MARGIN_ALLOW_E2E_SEED=1

# Default --user for the e2e seed CLI. Must match an already-connected user
# (sign in via the extension once with that account first). Only read when
# MARGIN_ALLOW_E2E_SEED=1.
# MARGIN_TEST_USER_EMAIL=
