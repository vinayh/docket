# Google OAuth credentials (from console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/oauth/callback

# 32-byte master key for envelope encryption, base64-encoded.
# Generate with: bun -e 'console.log(Buffer.from(crypto.getRandomValues(new Uint8Array(32))).toString("base64"))'
DOCKET_MASTER_KEY=

# SQLite database file
DOCKET_DB_PATH=./docket.db
