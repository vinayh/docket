{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable", "WebWorker"],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "include": [
    ".wxt/wxt.d.ts",
    "wxt.config.ts",
    "entrypoints/**/*",
    "utils/**/*",
    "components/**/*"
  ]
}
