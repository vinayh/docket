---
interface NavItem {
  href: string;
  label: string;
}
interface Props {
  items: NavItem[];
}
const { items } = Astro.props;
---

<aside class="hidden md:block w-48 shrink-0 sticky top-0 self-start h-dvh py-10 pl-8 pr-4">
  <a href="/" class="flex items-baseline gap-2 mb-1">
    <span class="font-display text-3xl leading-none">docket</span>
  </a>
  <div class="text-[11px] tracking-wide text-[color:var(--color-muted)] uppercase mb-10">
    v0.1.0 · alpha
  </div>

  <nav class="text-[13px]">
    <ul class="space-y-1.5">
      {items.map((item) => (
        <li>
          <a
            href={item.href}
            class="text-[color:var(--color-ink-2)] hover:text-[color:var(--color-ink)] hover:underline underline-offset-4 decoration-2 decoration-[color:var(--color-accent)]"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="mt-10 mb-3 text-[11px] tracking-wide text-[color:var(--color-muted)] uppercase">
      Links
    </div>
    <ul class="space-y-1.5">
      <li>
        <a
          href="https://github.com/vinayhiremath/docket"
          class="text-[color:var(--color-ink-2)] hover:text-[color:var(--color-ink)]"
          >GitHub</a
        >
      </li>
      <li>
        <a
          href="mailto:hello@docket.vinayh.com"
          class="text-[color:var(--color-ink-2)] hover:text-[color:var(--color-ink)]"
          >Contact</a
        >
      </li>
    </ul>
  </nav>
</aside>
