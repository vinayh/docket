---
interface Props {
  title?: string;
  caption?: string;
  variant?: "terminal" | "inline";
}
const { title = "~/project · docket", caption, variant = "terminal" } = Astro.props;
---

{variant === "terminal" ? (
  <figure class="my-6">
    <div
      class="rounded-lg overflow-hidden border border-black/10 shadow-[0_2px_0_rgba(0,0,0,0.04),0_18px_40px_-20px_rgba(0,0,0,0.35)]"
      style="background: var(--color-term-bg); color: var(--color-term-fg);"
    >
      <header class="flex items-center px-3 py-2 text-[12px] border-b border-white/5">
        <span class="flex gap-1.5 mr-3">
          <span class="w-3 h-3 rounded-full bg-[#ff5f57]"></span>
          <span class="w-3 h-3 rounded-full bg-[#febc2e]"></span>
          <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
        </span>
        <span class="flex-1 text-center font-mono text-white/60">{title}</span>
        <span class="text-white/60 font-mono text-[11px]">zsh</span>
      </header>
      <pre class="px-4 py-4 text-[13px] leading-6 font-mono whitespace-pre overflow-x-auto"><slot /></pre>
    </div>
    {caption && (
      <figcaption class="mt-2 text-[12px] text-[color:var(--color-muted)] font-mono">
        · {caption}
      </figcaption>
    )}
  </figure>
) : (
  <code
    class="font-mono text-[13px] px-1.5 py-0.5 rounded"
    style="background: var(--color-cream-2); color: var(--color-ink);"
  >
    <slot />
  </code>
)}
