---
import Highlight from "./Highlight.astro";
---

<section class="pt-16 pb-12">
  <h1 class="font-display text-[44px] sm:text-[56px] md:text-[68px] leading-[0.95] mb-6">
    Comments on Google&nbsp;Docs,<br />
    where you actually work.
  </h1>
  <p class="text-[17px] leading-7 text-[color:var(--color-ink-2)] max-w-[60ch] mb-8">
    A browser extension that pulls every comment, suggestion, and reply from
    your Google Docs into a project workspace.
    <Highlight>Feedback stays readable across versions and easy to reconcile, even after the text moves.</Highlight>
  </p>

  <div class="flex flex-wrap items-center gap-3">
    <a
      href="#install"
      class="inline-flex items-center gap-2 rounded-md bg-[color:var(--color-ink)] text-white px-4 py-2.5 text-[14px] font-medium hover:bg-[color:var(--color-ink-2)]"
    >
      Add to your browser
    </a>
    <a
      href="https://github.com/vinayh/margin"
      class="inline-flex items-center gap-2 rounded-md border border-black/15 px-4 py-2.5 text-[14px] font-medium hover:bg-black/5"
    >
      View on GitHub
      <span aria-hidden="true">↗</span>
    </a>
  </div>
</section>
